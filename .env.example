# Copy this file to /etc/atradimai/atradimai.env on the server. Never commit it.
FORM_RECIPIENT_EMAIL=atradimai@atradimai.lt
MAIL_FROM_EMAIL=atradimai@atradimai.lt
MAIL_FROM_NAME=Atradimai.lt
FORM_DATA_DIR=/var/lib/atradimai/submissions
FORM_UPLOAD_DIR=/var/lib/atradimai/uploads
# Create a Resend API key with sending permission. The atradimai.lt domain
# must first be verified in the same Resend account.
RESEND_API_KEY=
# Optional: receives newsletter-consent records in JSON format.
NEWSLETTER_WEBHOOK_URL=
# Paysera credentials belong only in this server file. Rotate the old password
# before setting it here, because it was tracked in the historic repository.
SITE_ORIGIN=https://atradimai.lt
PAYSERA_PROJECT_ID=69154
PAYSERA_SIGN_PASSWORD=
PAYSERA_AMOUNT_CENTS=4700
PAYSERA_CURRENCY=EUR
PAYSERA_TEST=0
PAYSERA_ORDER_DIR=/var/lib/atradimai/orders
