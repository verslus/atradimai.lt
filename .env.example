# Copy this file to /etc/atradimai/atradimai.env on the server. Never commit it.
FORM_RECIPIENT_EMAIL=info@example.com
MAIL_FROM_EMAIL=noreply@example.com
MAIL_FROM_NAME=Atradimai.lt
FORM_DATA_DIR=/var/lib/atradimai/submissions
FORM_UPLOAD_DIR=/var/lib/atradimai/uploads
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=change-me
SMTP_PASSWORD=change-me
SMTP_ENCRYPTION=tls
# Optional: receives newsletter-consent records in JSON format.
NEWSLETTER_WEBHOOK_URL=
# Must be a configured HTTPS payment page. Do not commit payment credentials.
PAYSERA_PAYMENT_URL=
